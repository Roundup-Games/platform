# Runtime
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-domain.com

DB_CONNECTION=pgsql
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=roundup_games
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Redis (external infrastructure — not managed by Docker Compose)
# Predis is used as the pure-PHP client (no phpredis extension needed).
# Ensure the app and worker containers can reach this host/port.
REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# PHP Performance
PHP_OPCACHE_ENABLE=1

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Mail
# Set to 'resend' when RESEND_API_KEY is configured. Leave empty to auto-detect.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (fill in your values)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Paddle Billing (fill in your values)
PADDLE_SELLER_ID=
PADDLE_AUTH_CODE=
PADDLE_API_KEY=
PADDLE_CLIENT_SIDE_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_SANDBOX=true

PADDLE_ANNUAL_PRICE_ID=
PADDLE_MONTHLY_PRICE_ID=

# Cashier
CASHIER_CURRENCY=USD
CASHIER_CURRENCY_LOCALE=en
CASHIER_PATH=paddle

# Resend (fill in your value)
RESEND_API_KEY=

# Attendance
ATTENDANCE_REPORTING_WINDOW_HOURS=72
ATTENDANCE_AUTO_COMPLETE_OFFSET_HOURS=12

# Escalated Plugin SDK (enable in production if using SDK plugins)
ESCALATED_PLUGINS_ENABLED=true
