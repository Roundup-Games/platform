# PHPStan baseline — generated after the migration squash.
#
# These 50 errors are NOT bugs. They are style findings (unnecessary nullsafe
# calls, redundant null comparisons, dead code branches) that became visible
# because the squashed SQL schema provides more accurate NOT NULL constraints
# than the original migration Blueprint parser. The SchemaAggregator could not
# track ALTER COLUMN ... SET NOT NULL changes across migrations; the SQL dump
# reflects the final, correct state.
#
# The application code defensively handles null on columns that are actually
# NOT NULL. This is harmless and often correct in practice (e.g., a model
# that hasn't been saved yet has null timestamps in PHP even if the DB column
# is NOT NULL).
#
# Regenerate after re-squashing:
#   php scripts/generate-larastan-schema.php
#   vendor/bin/phpstan analyse --generate-baseline=phpstan-baseline.neon
parameters:
	ignoreErrors:
		-
			message: '#^Using nullsafe method call on non\-nullable type Carbon\\Carbon\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 6
			path: app/Console/Commands/GenerateUserDataExport.php

		-
			message: '#^Call to function is_string\(\) with string will always evaluate to true\.$#'
			identifier: function.alreadyNarrowedType
			count: 1
			path: app/Console/Commands/HashShortLinkIps.php

		-
			message: '#^Expression on left side of \?\? is not nullable\.$#'
			identifier: nullCoalesce.expr
			count: 2
			path: app/Http/Controllers/SitemapController.php

		-
			message: '#^Using nullsafe method call on non\-nullable type Carbon\\Carbon\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 2
			path: app/Http/Controllers/SitemapController.php

		-
			message: '#^Using nullsafe method call on non\-nullable type Carbon\\Carbon\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Livewire/Billing/BillingPortal.php

		-
			message: '#^If condition is always true\.$#'
			identifier: if.alwaysTrue
			count: 1
			path: app/Livewire/Billing/MembershipPage.php

		-
			message: '#^Result of \|\| is always true\.$#'
			identifier: booleanOr.alwaysTrue
			count: 1
			path: app/Livewire/Campaigns/PublicCampaignDetail.php

		-
			message: '#^Strict comparison using \!\=\= between string and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: app/Livewire/Campaigns/PublicCampaignDetail.php

		-
			message: '#^Strict comparison using \=\=\= between string and null will always evaluate to false\.$#'
			identifier: identical.alwaysFalse
			count: 1
			path: app/Livewire/Campaigns/PublicCampaignDetail.php

		-
			message: '#^Strict comparison using \!\=\= between float and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 3
			path: app/Livewire/Games/CreateGame.php

		-
			message: '#^Result of \|\| is always true\.$#'
			identifier: booleanOr.alwaysTrue
			count: 1
			path: app/Livewire/Games/GameDetail.php

		-
