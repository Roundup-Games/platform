#!/command/with-contenv bash
# S6 initialization script — runs once before main processes start
# /etc/cont-init.d/ scripts are executed by S6 Overlay on container start

cd /var/www/html

# Create the database if it doesn't exist (external Postgres)
if [ "${DB_CONNECTION}" = "pgsql" ] && [ -n "${DB_HOST}" ]; then
    echo "Ensuring database '${DB_DATABASE}' exists on ${DB_HOST}:${DB_PORT}..."
    PGPASSWORD="${DB_PASSWORD}" psql -h "${DB_HOST}" -p "${DB_PORT}" -U "${DB_USERNAME}" \
        -d postgres -tc "SELECT 1 FROM pg_database WHERE datname = '${DB_DATABASE}'" | grep -q 1 || \
    PGPASSWORD="${DB_PASSWORD}" psql -h "${DB_HOST}" -p "${DB_PORT}" -U "${DB_USERNAME}" \
        -d postgres -c "CREATE DATABASE ${DB_DATABASE};"
    echo "Database ready."
fi

# Generate app key if not set — persist to .env so it survives restarts
if [ -z "${APP_KEY}" ]; then
    echo "Generating APP_KEY..."
    GENERATED_KEY=$(php artisan key:generate --show)
    export APP_KEY="${GENERATED_KEY}"

    # Write to .env file so the key persists across container restarts
    if [ -f .env ]; then
        if grep -q '^APP_KEY=' .env; then
            sed -i "s|^APP_KEY=.*|APP_KEY=${GENERATED_KEY}|" .env
        else
            echo "APP_KEY=${GENERATED_KEY}" >> .env
        fi
    fi
fi

# Run migrations
echo "Running migrations..."
php artisan migrate --force

# Cache config, routes, views for production
echo "Caching config, routes, views..."
php artisan config:cache
php artisan route:cache
php artisan view:cache

# Seed Escalated helpdesk data (departments, tags, SLA policies) — idempotent
# Allow errors to surface in container logs for debugging; || true prevents script failure
echo "Seeding Escalated helpdesk data..."
php artisan db:seed --force --class=EscalatedSetupSeeder || true

# Write deploy timestamp for admin dashboard
date -u +"%Y-%m-%d %H:%M:%S UTC" > /var/www/html/storage/framework/deploy-timestamp

echo "Laravel startup complete."
